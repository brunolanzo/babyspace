<%- include('../partials/sidebar') %>

<div class="main">
  <%- include('../partials/topbar') %>

  <div class="content">
    <div class="page-header">
      <div><p style="color:var(--color-text-light);font-size:0.9rem">Convidados que confirmaram presença pelo convite</p></div>
    </div>

    <div class="stats-bar">
      <div class="stat-mini"><div class="stat-mini-dot" style="background:var(--color-text)"></div><div><div class="stat-mini-value" id="statTotal">0</div><div class="stat-mini-label">Total de pessoas</div></div></div>
      <div class="stat-mini"><div class="stat-mini-dot" style="background:var(--color-accent)"></div><div><div class="stat-mini-value" id="statRsvps">0</div><div class="stat-mini-label">Confirmações</div></div></div>
      <div class="stat-mini"><div class="stat-mini-dot" style="background:#C3B1E1"></div><div><div class="stat-mini-value" id="statCompanions">0</div><div class="stat-mini-label">Acompanhantes</div></div></div>
      <div class="stat-mini"><div class="stat-mini-dot" style="background:#FFE5A0"></div><div><div class="stat-mini-value" id="statChildren">0</div><div class="stat-mini-label">Crianças</div></div></div>
    </div>

    <div class="filter-bar">
      <input type="text" class="search-input" placeholder="Buscar convidado..." id="searchBox" oninput="renderGuests()">
    </div>

    <!-- Desktop table -->
    <div class="table-wrap">
      <table>
        <thead><tr><th>Convidado</th><th>Acompanhantes</th><th>Crianças</th><th>Data RSVP</th><th></th></tr></thead>
        <tbody id="guestsTable"></tbody>
      </table>
    </div>

    <!-- Mobile cards -->
    <div class="mobile-cards" id="guestsMobile"></div>
  </div>
</div>
