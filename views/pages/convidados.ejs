<%- include('../partials/sidebar') %>

<div class="main">
  <%- include('../partials/topbar') %>

  <div class="content">
    <div class="page-header">
      <div><p style="color:var(--color-text-light);font-size:0.9rem">Gerencie seus convidados e acompanhe o RSVP</p></div>
      <div class="header-actions">
        <button class="btn btn-outline" onclick="openModal()">+ Adicionar</button>
        <button class="btn btn-whatsapp">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.14-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.61-.92-2.2-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.06 2.88 1.21 3.08c.15.2 2.09 3.19 5.06 4.47.71.3 1.26.49 1.69.63.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2.01-1.41.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/></svg>
          Enviar convites
        </button>
      </div>
    </div>

    <div class="stats-bar">
      <div class="stat-mini"><div class="stat-mini-dot" style="background:var(--color-text)"></div><div><div class="stat-mini-value">0</div><div class="stat-mini-label">Total</div></div></div>
      <div class="stat-mini"><div class="stat-mini-dot" style="background:var(--color-accent)"></div><div><div class="stat-mini-value">0</div><div class="stat-mini-label">Confirmados</div></div></div>
      <div class="stat-mini"><div class="stat-mini-dot" style="background:#D4A843"></div><div><div class="stat-mini-value">0</div><div class="stat-mini-label">Pendentes</div></div></div>
      <div class="stat-mini"><div class="stat-mini-dot" style="background:#E74C3C"></div><div><div class="stat-mini-value">0</div><div class="stat-mini-label">Recusaram</div></div></div>
    </div>

    <div class="filter-bar">
      <input type="text" class="search-input" placeholder="Buscar convidado...">
      <select class="filter-select">
        <option>Todos os status</option>
        <option>Confirmados</option>
        <option>Pendentes</option>
        <option>Recusaram</option>
      </select>
    </div>

    <div class="table-wrap">
      <table>
        <thead><tr><th>Convidado</th><th>E-mail</th><th>Status</th><th>Presente</th><th>Data RSVP</th><th></th></tr></thead>
        <tbody>
          <tr><td colspan="6" style="text-align:center;padding:48px 16px;color:var(--color-text-light)">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" style="opacity:0.3;margin-bottom:12px"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            <p style="font-weight:600;color:var(--color-text);margin-bottom:4px">Nenhum convidado adicionado</p>
            <p style="font-size:0.85rem">Clique em "+ Adicionar" para convidar seus amigos e familiares</p>
          </td></tr>
        </tbody>
      </table>
    </div>

    <!-- Mobile cards -->
    <div class="mobile-card">
      <div style="text-align:center;padding:32px 16px;color:var(--color-text-light)">
        <p style="font-weight:600;color:var(--color-text)">Nenhum convidado adicionado</p>
        <p style="font-size:0.85rem">Use o botão "+ Adicionar" acima</p>
      </div>
    </div>
  </div>
</div>

<div class="modal-overlay" id="guestModal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <h2>Adicionar convidado</h2>
    <form onsubmit="event.preventDefault();closeModal();">
      <div class="form-group"><label>Nome</label><input type="text" class="form-input" placeholder="Nome do convidado"></div>
      <div class="form-group"><label>E-mail</label><input type="email" class="form-input" placeholder="email@exemplo.com"></div>
      <div class="form-group"><label>Telefone (opcional)</label><input type="tel" class="form-input" placeholder="(11) 99999-9999"></div>
      <div class="modal-actions">
        <button type="button" class="btn btn-outline" onclick="closeModal()">Cancelar</button>
        <button type="submit" class="btn btn-primary">Adicionar</button>
      </div>
    </form>
  </div>
</div>
