<%- include('../partials/deco-bubbles') %>

<div class="auth-wrapper">
  <%- include('../partials/auth-logo') %>

  <div class="auth-card">
    <!-- State 1: Request -->
    <div id="stateRequest">
      <svg width="90" height="90" viewBox="0 0 90 90" fill="none" style="margin-bottom:16px">
        <circle cx="45" cy="45" r="36" fill="#FFE4D6"/>
        <rect x="22" y="32" width="46" height="28" rx="6" fill="#fff" stroke="#FF8C69" stroke-width="2"/>
        <path d="M22 38 L45 52 L68 38" stroke="#FF8C69" stroke-width="2" fill="none"/>
        <path d="M45 22 Q39 16 45 20 Q51 16 45 22" fill="#FF8C69" opacity="0.6"/>
        <path d="M45 18 Q41 14 45 17 Q49 14 45 18" fill="#FF8C69"/>
      </svg>
      <h1>Esqueceu sua senha?</h1>
      <p class="desc">Sem problemas! Digite seu e-mail e enviaremos um link para você criar uma nova senha.</p>
      <form id="resetForm" novalidate>
        <div class="form-group">
          <label for="email">E-mail</label>
          <input type="email" id="email" class="form-input" placeholder="seu@email.com" required>
        </div>
        <button type="submit" class="btn btn-primary">Enviar link de recuperação</button>
      </form>
      <a href="/login" class="back-link">← Voltar ao login</a>
    </div>

    <!-- State 2: Success -->
    <div id="stateSuccess">
      <svg width="100" height="100" viewBox="0 0 100 100" fill="none" style="margin-bottom:16px">
        <circle cx="50" cy="50" r="40" fill="#EDE9F8"/>
        <rect x="24" y="35" width="52" height="32" rx="6" fill="#fff" stroke="#A8D8B9" stroke-width="2.5"/>
        <path d="M24 41 L50 56 L76 41" stroke="#A8D8B9" stroke-width="2.5" fill="none"/>
        <circle cx="62" cy="30" r="12" fill="#A8D8B9"/>
        <path d="M57 30 L60 33 L67 26" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <h1 style="color:var(--color-accent)">E-mail enviado!</h1>
      <p class="desc">Enviamos um link de recuperação para <span class="email-display" id="emailDisplay"></span>. Verifique sua caixa de entrada e a pasta de spam.</p>
      <a href="/login" class="btn btn-primary" style="margin-bottom:8px">Voltar ao login</a>
      <span class="resend-link" id="resendBtn">Não recebeu? Reenviar e-mail</span>
      <p class="resend-feedback" id="resendFeedback">✓ E-mail reenviado!</p>
    </div>
  </div>
</div>
