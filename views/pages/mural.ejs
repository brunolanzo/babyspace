<%- include('../partials/sidebar') %>

<div class="main">
  <%- include('../partials/topbar') %>

  <div class="content">
    <!-- Page Header -->
    <div class="page-header">
      <div>
        <h2 style="font-size:1.3rem;margin-bottom:4px">Mural de Recados</h2>
        <p style="color:var(--color-text-light);font-size:0.9rem">Gerencie as mensagens dos convidados</p>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-outline btn-sm" onclick="filterMessages('pending')" id="btnPending">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          Pendentes (<span id="pendingCount">0</span>)
        </button>
        <button class="btn btn-primary btn-sm" onclick="document.getElementById('shareModal').classList.add('open')">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M16 6l-4-4-4 4M12 2v13"/></svg>
          Compartilhar link
        </button>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="stats-bar">
      <div class="stat-mini">
        <div class="stat-mini-value" id="statTotal">0</div>
        <div class="stat-mini-label">Total de recados</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-value" id="statApproved" style="color:var(--color-accent)">0</div>
        <div class="stat-mini-label">Aprovados</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-value" id="statPending" style="color:var(--color-primary)">0</div>
        <div class="stat-mini-label">Pendentes</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-value" id="statPinned">0</div>
        <div class="stat-mini-label">Fixados</div>
      </div>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar">
      <input type="text" class="search-box" placeholder="Buscar recados..." id="searchBox" oninput="renderMessages()">
      <select class="filter-select" id="filterSelect" onchange="renderMessages()">
        <option value="all">Todos</option>
        <option value="pinned">Fixados</option>
        <option value="approved">Aprovados</option>
        <option value="pending">Pendentes</option>
      </select>
    </div>

    <!-- Mural Grid -->
    <div class="mural-grid" id="muralGrid"></div>
  </div>
</div>

<!-- Share Modal -->
<div class="modal-overlay" id="shareModal">
  <div class="modal">
    <h2>Compartilhar Mural</h2>
    <p style="color:var(--color-text-light);margin-bottom:16px;font-size:0.9rem">Compartilhe o link para que mais pessoas deixem mensagens carinhosas.</p>
    <div style="background:var(--color-bg);border-radius:var(--radius-sm);padding:12px 16px;font-family:monospace;font-size:0.85rem;color:var(--color-text-light);margin-bottom:12px;word-break:break-all" id="shareUrl">Carregando...</div>
    <div class="modal-actions">
      <button class="btn btn-primary" onclick="copyShareLink()">Copiar link</button>
      <button class="btn btn-outline" onclick="document.getElementById('shareModal').classList.remove('open')">Fechar</button>
    </div>
  </div>
</div>

<%- include('../partials/toast') %>
