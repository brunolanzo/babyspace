<%- include('../partials/sidebar') %>
<div class="main">
  <%- include('../partials/topbar') %>
  <div class="content">
    <!-- Balance Card -->
    <div class="balance-card">
      <div>
        <div class="balance-label">Saldo disponível para resgate</div>
        <div class="balance-value">R$ 2.450,00</div>
        <div class="balance-sub">Atualizado há 2 horas • Chá da Helena</div>
      </div>
      <div class="balance-actions">
        <button class="btn btn-white" onclick="showToast('Solicitação de resgate enviada!')">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
          Solicitar resgate
        </button>
      </div>
    </div>

    <!-- Stats Row -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-card-value" style="color:var(--color-accent)">R$ 3.200,00</div>
        <div class="stat-card-label">Total arrecadado</div>
      </div>
      <div class="stat-card">
        <div class="stat-card-value" style="color:var(--color-primary)">R$ 750,00</div>
        <div class="stat-card-label">Já resgatado</div>
      </div>
      <div class="stat-card">
        <div class="stat-card-value" style="color:var(--color-secondary)">R$ 2.450,00</div>
        <div class="stat-card-label">Disponível</div>
      </div>
    </div>

    <!-- Two columns -->
    <div class="two-col">
      <!-- Bank form -->
      <div class="card-block">
        <h3>Dados bancários para resgate</h3>
        <div class="form-group">
          <label>Banco</label>
          <select class="form-select">
            <option>Selecione o banco</option>
            <option selected>Nubank (260)</option>
            <option>Banco do Brasil (001)</option>
            <option>Itaú (341)</option>
            <option>Bradesco (237)</option>
            <option>Santander (033)</option>
            <option>Caixa (104)</option>
            <option>Inter (077)</option>
            <option>C6 Bank (336)</option>
          </select>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Agência</label>
            <input type="text" class="form-input" placeholder="0001" value="0001">
          </div>
          <div class="form-group">
            <label>Conta</label>
            <input type="text" class="form-input" placeholder="12345-6" value="98765-4">
          </div>
        </div>
        <div class="form-group">
          <label>Tipo de conta</label>
          <select class="form-select">
            <option selected>Conta Corrente</option>
            <option>Conta Poupança</option>
          </select>
        </div>
        <div class="form-group">
          <label>CPF do titular</label>
          <input type="text" class="form-input" placeholder="000.000.000-00" value="***.***.***-45">
        </div>
        <div class="form-group">
          <label>Nome do titular</label>
          <input type="text" class="form-input" placeholder="Nome completo" value="Camila Lima Santos">
        </div>
        <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="showToast('Dados bancários salvos!')">Salvar dados bancários</button>

        <div class="info-box">
          <p>💡 <strong>Taxas:</strong> 3.9% do valor arrecadado + R$ 0,50 por transação</p>
          <p>⏱️ <strong>Prazo:</strong> Transferência em até 2 dias úteis</p>
          <p>💰 <strong>Valor mínimo:</strong> R$ 50,00 por resgate</p>
        </div>
      </div>

      <!-- History -->
      <div class="card-block">
        <h3>Histórico de resgates</h3>
        <div class="table-wrapper">
          <table class="history-table">
            <thead>
              <tr>
                <th>Data</th>
                <th>Valor</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>28/02/2026</td>
                <td style="font-weight:600">R$ 500,00</td>
                <td><span class="status-badge badge-processing">Em processamento</span></td>
              </tr>
              <tr>
                <td>15/02/2026</td>
                <td style="font-weight:600">R$ 250,00</td>
                <td><span class="status-badge badge-success">Concluído</span></td>
              </tr>
              <tr>
                <td>01/02/2026</td>
                <td style="font-weight:600">R$ 350,00</td>
                <td><span class="status-badge badge-success">Concluído</span></td>
              </tr>
              <tr>
                <td>18/01/2026</td>
                <td style="font-weight:600">R$ 400,00</td>
                <td><span class="status-badge badge-success">Concluído</span></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div style="margin-top:24px;padding-top:20px;border-top:1px solid #f0ece9">
          <h4 style="font-size:1rem;margin-bottom:12px">Detalhes das taxas</h4>
          <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:0.9rem;border-bottom:1px solid #f0ece9">
            <span>Total arrecadado</span><span style="font-weight:600">R$ 3.200,00</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:0.9rem;border-bottom:1px solid #f0ece9">
            <span>Taxa da plataforma (3.9%)</span><span style="font-weight:600;color:#E74C3C">-R$ 124,80</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:0.9rem;border-bottom:1px solid #f0ece9">
            <span>Taxa por transação (12x R$ 0,50)</span><span style="font-weight:600;color:#E74C3C">-R$ 6,00</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:0.9rem;border-bottom:1px solid #f0ece9">
            <span>Já resgatado</span><span style="font-weight:600;color:var(--color-primary)">-R$ 750,00</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:10px 0;font-family:'Nunito',sans-serif;font-weight:800;font-size:1rem;color:var(--color-accent)">
            <span>Disponível para resgate</span><span>R$ 2.319,20</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/toast') %>
