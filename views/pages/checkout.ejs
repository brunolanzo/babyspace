<div class="checkout-wrapper">
  <a href="/" class="checkout-logo">
    <svg width="28" height="28" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="14" fill="#FF8C69" opacity="0.15"/><path d="M16 6 L18.5 12 L25 12.5 L20 17 L21.5 24 L16 20.5 L10.5 24 L12 17 L7 12.5 L13.5 12 Z" fill="#FF8C69"/></svg>
    BabySpace
  </a>

  <div id="checkoutForm">
    <a href="/convite" class="back-link">← Voltar ao convite</a>

    <div class="gift-summary">
      <div class="gift-summary-icon">🛏️</div>
      <div>
        <h3>Berço Portátil</h3>
        <p>Presente para o chá de bebê</p>
        <div class="price">R$ 350,00</div>
      </div>
    </div>

    <div class="checkout-card">
      <h2>Seus dados</h2>
      <div class="form-group"><label>Seu nome</label><input type="text" class="form-input" placeholder="Nome completo"></div>
      <div class="form-group"><label>Seu e-mail</label><input type="email" class="form-input" placeholder="seu@email.com"></div>
      <div class="form-group"><label>Mensagem para os pais (opcional)</label><textarea class="form-textarea" placeholder="Deixe uma mensagem carinhosa..." rows="2"></textarea></div>
    </div>

    <div class="checkout-card">
      <h2>Forma de pagamento</h2>
      <div class="payment-tabs">
        <div class="pay-tab active" onclick="switchTab('pix',this)"><span class="pay-tab-icon">📱</span>Pix</div>
        <div class="pay-tab" onclick="switchTab('boleto',this)"><span class="pay-tab-icon">📄</span>Boleto</div>
        <div class="pay-tab" onclick="switchTab('cartao',this)"><span class="pay-tab-icon">💳</span>Cartão</div>
      </div>

      <div class="tab-content active" id="tab-pix">
        <div class="pix-area">
          <div class="pix-qr">QR Code Pix<br>aparecerá aqui</div>
          <div class="pix-code">00020126580014br.gov.bcb.pix0136babyspace-exemplo-chave-pix</div>
          <button class="btn btn-outline" onclick="this.textContent='✓ Código copiado!'">📋 Copiar código Pix</button>
          <p style="margin-top:12px;font-size:0.82rem;color:var(--color-text-light)">Válido por 30 minutos • Pagamento instantâneo</p>
        </div>
      </div>

      <div class="tab-content" id="tab-boleto">
        <div style="text-align:center;padding:24px;background:var(--color-bg);border-radius:var(--radius-md)">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-light)" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 8h10M7 12h6"/></svg>
          <p style="margin:12px 0;color:var(--color-text-light);font-size:0.9rem">O boleto será gerado e pode ser pago em qualquer banco.</p>
          <p style="font-size:0.82rem;color:var(--color-text-light)">Prazo de compensação: até 3 dias úteis</p>
        </div>
      </div>

      <div class="tab-content" id="tab-cartao">
        <div class="form-group"><label>Número do cartão</label><input type="text" class="form-input" placeholder="0000 0000 0000 0000" maxlength="19"></div>
        <div class="form-row">
          <div class="form-group"><label>Validade</label><input type="text" class="form-input" placeholder="MM/AA" maxlength="5"></div>
          <div class="form-group"><label>CVV</label><input type="text" class="form-input" placeholder="123" maxlength="4"></div>
        </div>
        <div class="form-group"><label>Nome no cartão</label><input type="text" class="form-input" placeholder="Como está no cartão"></div>
      </div>

      <div class="order-summary">
        <div class="order-row"><span>Valor do presente</span><span>R$ 350,00</span></div>
        <div class="order-row"><span>Taxa da plataforma</span><span>R$ 12,95</span></div>
        <div class="order-row total"><span>Total</span><span>R$ 362,95</span></div>
      </div>
    </div>

    <button class="btn btn-primary" style="padding:16px;font-size:1rem" onclick="showSuccess()">Pagar R$ 362,95</button>

    <div class="seals">
      <span class="seal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        SSL Seguro
      </span>
      <span class="seal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Pagamento Seguro
      </span>
    </div>
  </div>

  <!-- Success State -->
  <div class="success-state" id="successState">
    <div class="success-check">✓</div>
    <h2>Pagamento confirmado! 🎉</h2>
    <p>Seu presente foi registrado com sucesso.<br>Os pais serão notificados. Obrigado pelo carinho!</p>
    <div style="background:#fff;border-radius:var(--radius-md);padding:20px;margin-bottom:24px;box-shadow:var(--shadow-card);text-align:left">
      <div class="order-row"><span>Presente:</span><span>Berço Portátil</span></div>
      <div class="order-row"><span>Valor:</span><span>R$ 362,95</span></div>
      <div class="order-row"><span>Método:</span><span>Pix</span></div>
    </div>
    <a href="/convite" class="btn btn-primary" style="display:inline-flex;width:auto;padding:14px 32px">Voltar ao convite</a>
  </div>
</div>
