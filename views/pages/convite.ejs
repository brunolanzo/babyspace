<section class="invite-hero">
  <div class="deco d1"></div><div class="deco d2"></div><div class="deco d3"></div>
  <div class="invite-logo">
    <svg width="20" height="20" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="14" fill="#FF8C69" opacity="0.15"/><path d="M16 6 L18.5 12 L25 12.5 L20 17 L21.5 24 L16 20.5 L10.5 24 L12 17 L7 12.5 L13.5 12 Z" fill="#FF8C69"/></svg>
    BabySpace
  </div>
  <h1>Chá da <span>Helena</span> 💕</h1>
  <p class="subtitle">Camila e Lucas convidam você para celebrar a chegada da Helena!</p>
  <div class="countdown">
    <div class="countdown-item"><div class="countdown-num" id="days">45</div><div class="countdown-label">Dias</div></div>
    <div class="countdown-item"><div class="countdown-num" id="hours">12</div><div class="countdown-label">Horas</div></div>
    <div class="countdown-item"><div class="countdown-num" id="mins">30</div><div class="countdown-label">Min</div></div>
    <div class="countdown-item"><div class="countdown-num" id="secs">00</div><div class="countdown-label">Seg</div></div>
  </div>
</section>

<div class="container">
  <div class="parents">
    <div><div class="parent-avatar">CA</div><p class="parent-name">Camila</p></div>
    <span class="parents-heart">♥</span>
    <div><div class="parent-avatar" style="background:var(--color-secondary-light);color:var(--color-secondary)">LA</div><p class="parent-name">Lucas</p></div>
  </div>

  <section class="section">
    <h2 class="section-title">Detalhes do evento</h2>
    <div class="details-grid">
      <div class="detail-card"><div class="detail-icon">📅</div><div class="detail-label">Data</div><div class="detail-value">19 de Abril, 2026</div></div>
      <div class="detail-card"><div class="detail-icon">🕐</div><div class="detail-label">Horário</div><div class="detail-value">15:00</div></div>
      <div class="detail-card"><div class="detail-icon">📍</div><div class="detail-label">Local</div><div class="detail-value">Espaço Festas Jardim</div></div>
      <div class="detail-card"><div class="detail-icon">🎨</div><div class="detail-label">Tema</div><div class="detail-value">Nuvens</div></div>
    </div>
  </section>
</div>

<section class="gifts-section">
  <div class="gifts-inner">
    <h2 class="section-title">Lista de Presentes</h2>
    <p style="text-align:center;color:var(--color-text-light);margin-bottom:8px">Escolha um presente para a Helena</p>
    <div class="gifts-grid">
      <div class="gift-card">
        <div class="gift-icon" style="background:var(--color-primary-light)">🛒</div>
        <p class="gift-name">Carrinho de Bebê</p>
        <p class="gift-price">R$ 450,00</p>
        <div class="gift-progress"><div class="gift-progress-fill" style="width:100%"></div></div>
        <button class="btn btn-done btn-full">✓ Presenteado</button>
      </div>
      <div class="gift-card">
        <div class="gift-icon" style="background:var(--color-secondary-light)">👶</div>
        <p class="gift-name">Kit Enxoval</p>
        <p class="gift-price">R$ 280,00</p>
        <div class="gift-progress"><div class="gift-progress-fill" style="width:75%"></div></div>
        <a href="/checkout" class="btn btn-primary btn-full">Presentear</a>
      </div>
      <div class="gift-card">
        <div class="gift-icon" style="background:rgba(168,216,185,0.2)">🛏️</div>
        <p class="gift-name">Berço Portátil</p>
        <p class="gift-price">R$ 350,00</p>
        <div class="gift-progress"><div class="gift-progress-fill" style="width:45%"></div></div>
        <a href="/checkout" class="btn btn-primary btn-full">Presentear</a>
      </div>
      <div class="gift-card">
        <div class="gift-icon" style="background:rgba(255,229,160,0.2)">🛁</div>
        <p class="gift-name">Banheira</p>
        <p class="gift-price">R$ 180,00</p>
        <div class="gift-progress"><div class="gift-progress-fill" style="width:0%"></div></div>
        <a href="/checkout" class="btn btn-primary btn-full">Presentear</a>
      </div>
      <div class="gift-card">
        <div class="gift-icon" style="background:var(--color-primary-light)">🧴</div>
        <p class="gift-name">Kit Higiene</p>
        <p class="gift-price">R$ 120,00</p>
        <div class="gift-progress"><div class="gift-progress-fill" style="width:100%"></div></div>
        <button class="btn btn-done btn-full">✓ Presenteado</button>
      </div>
      <div class="gift-card">
        <div class="gift-icon" style="background:var(--color-secondary-light)">👗</div>
        <p class="gift-name">Roupinhas (P)</p>
        <p class="gift-price">R$ 200,00</p>
        <div class="gift-progress"><div class="gift-progress-fill" style="width:30%"></div></div>
        <a href="/checkout" class="btn btn-primary btn-full">Presentear</a>
      </div>
    </div>
  </div>
</section>

<div class="container">
  <section class="section">
    <h2 class="section-title">Confirme sua presença</h2>
    <div class="rsvp-card">
      <form id="rsvpForm" onsubmit="event.preventDefault();alert('Presença confirmada! 🎉')">
        <div class="form-group"><label>Seu nome</label><input type="text" class="form-input" placeholder="Nome completo" required></div>
        <div class="form-group"><label>E-mail</label><input type="email" class="form-input" placeholder="seu@email.com" required></div>
        <div class="form-group">
          <label>Você vai participar?</label>
          <div class="radio-row">
            <label class="radio-pill selected" onclick="selectPill(this)"><input type="radio" name="rsvp" value="sim" checked> 🎉 Vou sim!</label>
            <label class="radio-pill" onclick="selectPill(this)"><input type="radio" name="rsvp" value="nao"> 😢 Não poderei</label>
          </div>
        </div>
        <div class="form-group"><label>Deixe um recadinho (opcional)</label><textarea class="form-textarea" placeholder="Uma mensagem carinhosa para a família..." rows="3"></textarea></div>
        <button type="submit" class="btn btn-primary btn-full" style="padding:14px">Confirmar presença</button>
      </form>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Mural de Recados 💌</h2>
    <div class="messages-preview">
      <div class="msg-card" style="background:var(--color-primary-light)"><p class="msg-author">Ana Silva</p>"Mal posso esperar para conhecer a Helena! Muita saúde e amor pra vocês!"</div>
      <div class="msg-card" style="background:var(--color-secondary-light)"><p class="msg-author">Maria Costa</p>"Que Deus abençoe essa família linda! Helena é muito esperada!"</div>
      <div class="msg-card" style="background:rgba(168,216,185,0.15)"><p class="msg-author">Pedro Lima</p>"Parabéns, Camila e Lucas! A Helena já é muito amada por todos nós."</div>
    </div>
  </section>

  <section class="share-section">
    <h2 class="section-title">Compartilhe com carinho</h2>
    <p style="color:var(--color-text-light)">Envie este convite para quem você ama</p>
    <div class="share-btns">
      <button class="share-btn share-whatsapp">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.14-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.61-.92-2.2-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.06 2.88 1.21 3.08c.15.2 2.09 3.19 5.06 4.47.71.3 1.26.49 1.69.63.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2.01-1.41.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/></svg>
        Enviar pelo WhatsApp
      </button>
      <button class="share-btn share-copy" onclick="navigator.clipboard.writeText(location.href);this.textContent='✓ Link copiado!'">📋 Copiar link</button>
    </div>
  </section>
</div>

<footer class="invite-footer">
  <p>Feito com 💕 no BabySpace</p>
  <a href="/cadastro">Crie seu chá grátis →</a>
</footer>
