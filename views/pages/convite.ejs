<% if (event) { %>
<!-- ===== INVITE WITH REAL EVENT DATA ===== -->
<script>
  window.__conviteEvent = <%- JSON.stringify({
    chaDate: event.chaDate,
    pregnancyWeeks: event.pregnancyWeeks,
    weekCountDay: event.weekCountDay,
    createdAt: event.createdAt,
    slug: event.slug,
    eventId: event._id
  }).replace(/<\//g, '<\\/') %>;
</script>

<section class="invite-hero">
  <% if (event.coverPhoto) { %>
  <img class="invite-hero-cover" src="<%= event.coverPhoto %>?v=<%= v %>" alt="Foto de capa" style="object-position: center <%= event.coverPosition || 50 %>%">
  <div class="invite-hero-overlay"></div>
  <% } else { %>
  <div class="deco d1"></div><div class="deco d2"></div><div class="deco d3"></div>
  <% } %>
  <div class="invite-hero-content">
    <div class="invite-logo">
      <svg width="20" height="20" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="14" fill="#FF8C69" opacity="0.15"/><path d="M16 6 L18.5 12 L25 12.5 L20 17 L21.5 24 L16 20.5 L10.5 24 L12 17 L7 12.5 L13.5 12 Z" fill="#FF8C69"/></svg>
      BabySpace
    </div>
    <h1><%= event.chaTitle %></h1>
    <p class="subtitle">
      <% if (event.isGemeos && event.babyName && event.babyName2) { %>
        <%= event.babyName %> e <%= event.babyName2 %> estão chegando!
      <% } else if (event.babyName) { %>
        <%= event.babyName %> está chegando!
      <% } else { %>
        Um bebê está chegando!
      <% } %>
    </p>
    <% if (event.chaDate) { %>
    <div class="countdown" id="countdown">
      <div class="countdown-item"><div class="countdown-num" id="days">--</div><div class="countdown-label">Dias</div></div>
      <div class="countdown-item"><div class="countdown-num" id="hours">--</div><div class="countdown-label">Horas</div></div>
      <div class="countdown-item"><div class="countdown-num" id="mins">--</div><div class="countdown-label">Min</div></div>
      <div class="countdown-item"><div class="countdown-num" id="secs">--</div><div class="countdown-label">Seg</div></div>
    </div>
    <% } %>
  </div>
</section>

<div class="container">

  <% if (event.pregnancyWeeks) { %>
  <div class="pregnancy-badge" id="convitePregnancy"></div>
  <% } %>

  <% if (event.chaDesc) { %>
  <div class="section">
    <h2 class="section-title">Sobre o evento</h2>
    <p class="invite-description"><%= event.chaDesc %></p>
  </div>
  <% } %>

  <div class="section">
    <h2 class="section-title">Detalhes</h2>
    <div class="details-grid">
      <% if (event.chaDate) { %>
      <div class="detail-card">
        <div class="detail-icon">📅</div>
        <div class="detail-label">Data</div>
        <div class="detail-value"><%= new Date(event.chaDate + 'T12:00:00').toLocaleDateString('pt-BR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></div>
      </div>
      <% } %>
      <div class="detail-card">
        <div class="detail-icon"><%= event.modality === 'presencial' ? '📍' : '💻' %></div>
        <div class="detail-label">Modalidade</div>
        <div class="detail-value"><%= event.modality === 'presencial' ? 'Presencial' : 'Online' %></div>
      </div>
      <% if (event.modality === 'presencial' && event.chaLocation) { %>
      <div class="detail-card detail-card-full">
        <div class="detail-icon">🏠</div>
        <div class="detail-label">Local</div>
        <div class="detail-value"><%= event.chaLocation %></div>
      </div>
      <% } %>
    </div>
  </div>

  <% if (event.modality === 'presencial' && event.chaLocation) { %>
  <div class="section">
    <h2 class="section-title">Como chegar</h2>
    <div class="map-container">
      <iframe src="https://maps.google.com/maps?q=<%= encodeURIComponent(event.chaLocation) %>&output=embed" width="100%" height="300" style="border:0;border-radius:var(--radius-md)" allowfullscreen loading="lazy"></iframe>
    </div>
    <div style="text-align:center;margin-top:16px">
      <a href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(event.chaLocation) %>" target="_blank" rel="noopener" class="btn btn-outline">Abrir no Google Maps →</a>
    </div>
  </div>
  <% } %>

  <!-- RSVP Section -->
  <div class="section" id="rsvpSection">
    <h2 class="section-title">Confirme sua presença</h2>
    <div class="invite-card" id="rsvpCard">
      <form id="rsvpForm">
        <div class="form-group">
          <label class="form-label">Seu nome</label>
          <input type="text" id="rsvpName" class="form-input" required placeholder="Nome completo">
        </div>
        <div id="companionsContainer"></div>
        <button type="button" class="btn btn-outline btn-sm" id="addCompanionBtn" style="margin-top:8px">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
          Adicionar acompanhante
        </button>
        <button type="submit" class="btn btn-primary btn-full" style="margin-top:16px">Confirmar presença</button>
      </form>
      <div id="rsvpSuccess" class="success-state" style="display:none">
        <div class="success-icon">✅</div>
        <h3>Presença confirmada!</h3>
        <p>Obrigado por confirmar. Nos vemos no evento!</p>
      </div>
    </div>
  </div>

  <!-- Gift List Section -->
  <div class="section" id="giftSection">
    <h2 class="section-title">Lista de Presentes</h2>
    <div id="publicGiftsGrid" class="public-gifts-grid"></div>
    <div id="emptyGifts" class="empty-state-small" style="display:none">
      <p>Nenhum presente na lista ainda.</p>
    </div>
  </div>

  <!-- Cart floating bar -->
  <div id="cartBar" class="cart-bar" style="display:none">
    <div class="cart-bar-info">
      <span id="cartCount">0</span> presente(s) — <strong id="cartTotal">R$ 0</strong>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openCartModal()">Ver carrinho</button>
  </div>

  <!-- Cart Modal -->
  <div id="cartModal" class="modal-overlay" style="display:none">
    <div class="modal-content">
      <div class="modal-header">
        <h3>Seu carrinho</h3>
        <button class="modal-close" onclick="closeCartModal()">&times;</button>
      </div>
      <div id="cartItems" class="cart-items"></div>
      <div class="cart-total-row">
        <strong>Total:</strong> <strong id="cartModalTotal">R$ 0</strong>
      </div>
      <div class="form-group" style="margin-top:16px">
        <label class="form-label">Seu nome</label>
        <input type="text" id="cartGuestName" class="form-input" placeholder="Nome completo">
      </div>
      <div class="pix-info">
        <div class="pix-badge">PIX</div>
        <p>O pagamento será via PIX. Após confirmar, você receberá as instruções.</p>
      </div>
      <button class="btn btn-primary btn-full" onclick="submitPurchase()" id="purchaseBtn">Confirmar presente</button>
      <div id="purchaseSuccess" class="success-state" style="display:none">
        <div class="success-icon">🎉</div>
        <h3>Presente enviado!</h3>
        <p>Obrigado pela generosidade!</p>
      </div>
    </div>
  </div>

  <!-- Mural Section -->
  <div class="section" id="muralSection">
    <h2 class="section-title">Mural de Recados</h2>
    <div id="messagesWall" class="messages-wall"></div>
    <div class="mural-form-card">
      <form id="messageForm">
        <div class="form-group">
          <label class="form-label">Seu nome</label>
          <input type="text" id="msgName" class="form-input" placeholder="Seu nome" required>
        </div>
        <div class="form-group">
          <label class="form-label">Mensagem</label>
          <textarea id="msgText" class="form-input" placeholder="Deixe uma mensagem carinhosa..." rows="3" required maxlength="500"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Enviar recado 💌</button>
      </form>
      <div id="msgSuccess" class="success-state" style="display:none">
        <p>✨ Recado enviado com carinho!</p>
      </div>
    </div>
  </div>

  <div class="share-section">
    <h2 class="section-title">Compartilhe com os amigos</h2>
    <div class="share-btns">
      <button class="share-btn share-whatsapp" onclick="shareWhatsApp()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        WhatsApp
      </button>
      <button class="share-btn share-copy" onclick="copyLink()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        Copiar link
      </button>
    </div>
  </div>
</div>

<footer class="invite-footer">
  <p>Feito com BabySpace</p>
  <a href="/cadastro">Crie seu chá grátis</a>
</footer>

<% } else { %>
<!-- ===== EMPTY STATE (no event) ===== -->
<section class="invite-hero">
  <div class="deco d1"></div><div class="deco d2"></div><div class="deco d3"></div>
  <div class="invite-logo">
    <svg width="20" height="20" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="14" fill="#FF8C69" opacity="0.15"/><path d="M16 6 L18.5 12 L25 12.5 L20 17 L21.5 24 L16 20.5 L10.5 24 L12 17 L7 12.5 L13.5 12 Z" fill="#FF8C69"/></svg>
    BabySpace
  </div>
  <h1>Seu convite</h1>
  <p class="subtitle">Crie seu chá para gerar um convite personalizado!</p>
</section>

<div class="container">
  <div style="text-align:center;padding:64px 24px">
    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#FF8C69" stroke-width="1" stroke-linecap="round" style="opacity:0.4;margin-bottom:24px">
      <rect x="2" y="4" width="20" height="16" rx="2"/>
      <path d="M22 4L12 13L2 4"/>
    </svg>
    <h2 style="font-size:1.5rem;margin-bottom:8px;color:var(--color-text)">Nenhum convite criado ainda</h2>
    <p style="color:var(--color-text-light);margin-bottom:24px;max-width:400px;margin-left:auto;margin-right:auto">
      Quando você criar seu chá de bebê, um convite lindo como este será gerado automaticamente para compartilhar com seus convidados.
    </p>
    <a href="/criar-cha" class="btn btn-primary" style="padding:14px 32px;font-size:1rem">Criar meu chá agora</a>
  </div>
</div>

<footer class="invite-footer">
  <p>Feito com BabySpace</p>
  <a href="/cadastro">Crie seu chá grátis</a>
</footer>
<% } %>
