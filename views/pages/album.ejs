<%- include('../partials/sidebar') %>
<div class="main">
  <%- include('../partials/topbar') %>

  <div class="content">
    <!-- Page Header -->
    <div class="page-header">
      <div>
        <h2 style="font-size:1.3rem;margin-bottom:4px">Álbum de Fotos</h2>
        <p style="color:var(--color-text-light);font-size:0.9rem">Fotos do chá de bebê e momentos especiais</p>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-outline btn-sm" onclick="showToast('Link do álbum copiado!')">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M16 6l-4-4-4 4M12 2v13"/></svg>
          Compartilhar
        </button>
        <button class="btn btn-primary btn-sm" onclick="document.getElementById('fileInput').click()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
          Enviar fotos
        </button>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="stats-bar">
      <div class="stat-mini">
        <div class="stat-mini-value">0</div>
        <div class="stat-mini-label">Total de fotos</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-value">0</div>
        <div class="stat-mini-label">Enviadas por convidados</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-value">0</div>
        <div class="stat-mini-label">Enviadas por você</div>
      </div>
    </div>

    <!-- Upload zone -->
    <div class="upload-zone" id="uploadZone" onclick="document.getElementById('fileInput').click()">
      <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
        <circle cx="28" cy="28" r="24" fill="var(--color-primary-light)"/>
        <path d="M28 18v12M22 24l6-6 6 6" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M18 34h20" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
      <h3>Arraste e solte fotos aqui</h3>
      <p>ou clique para selecionar • JPG, PNG ou WEBP • Máximo 10MB por foto</p>
      <button class="btn btn-primary btn-sm" onclick="event.stopPropagation()">Selecionar arquivos</button>
      <input type="file" id="fileInput" multiple accept="image/*">
    </div>

    <!-- Photo grid -->
    <div class="photo-grid">
      <div style="grid-column:1/-1;text-align:center;padding:48px 16px;color:var(--color-text-light)">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" style="opacity:0.3;margin-bottom:16px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
        <p style="font-weight:600;color:var(--color-text);margin-bottom:4px;font-size:1.1rem">Nenhuma foto ainda</p>
        <p style="font-size:0.9rem">Use a área acima para enviar suas primeiras fotos!</p>
      </div>
    </div>
  </div>
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <button class="lightbox-close" onclick="closeLightbox()">✕</button>
  <div class="lightbox-content">
    <div class="lightbox-placeholder">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
      <span id="lightboxLabel">Foto</span>
    </div>
  </div>
  <div class="lightbox-info">
    <strong id="lightboxTitle">Decoração da mesa</strong>
    <span id="lightboxAuthor">Enviada por Camila</span>
  </div>
  <div class="lightbox-nav">
    <button class="lightbox-nav-btn" onclick="navLightbox(-1)">←</button>
    <button class="lightbox-nav-btn" onclick="navLightbox(1)">→</button>
  </div>
</div>

<%- include('../partials/toast') %>
