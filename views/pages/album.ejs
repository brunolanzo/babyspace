<%- include('../partials/sidebar') %>
<div class="main">
  <%- include('../partials/topbar') %>

  <div class="content">
    <!-- Page Header -->
    <div class="page-header">
      <div>
        <h2 style="font-size:1.3rem;margin-bottom:4px">Chá da Helena</h2>
        <p style="color:var(--color-text-light);font-size:0.9rem">Fotos do chá de bebê e momentos especiais</p>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-outline btn-sm" onclick="showToast('Link do álbum copiado!')">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M16 6l-4-4-4 4M12 2v13"/></svg>
          Compartilhar
        </button>
        <button class="btn btn-primary btn-sm" onclick="document.getElementById('fileInput').click()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
          Enviar fotos
        </button>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="stats-bar">
      <div class="stat-mini">
        <div class="stat-mini-value">24</div>
        <div class="stat-mini-label">Total de fotos</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-value">8</div>
        <div class="stat-mini-label">Enviadas por convidados</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-value">16</div>
        <div class="stat-mini-label">Enviadas por você</div>
      </div>
    </div>

    <!-- Upload zone -->
    <div class="upload-zone" id="uploadZone" onclick="document.getElementById('fileInput').click()">
      <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
        <circle cx="28" cy="28" r="24" fill="var(--color-primary-light)"/>
        <path d="M28 18v12M22 24l6-6 6 6" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M18 34h20" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
      <h3>Arraste e solte fotos aqui</h3>
      <p>ou clique para selecionar • JPG, PNG ou WEBP • Máximo 10MB por foto</p>
      <button class="btn btn-primary btn-sm" onclick="event.stopPropagation()">Selecionar arquivos</button>
      <input type="file" id="fileInput" multiple accept="image/*">
    </div>

    <!-- Photo grid -->
    <div class="photo-grid">
      <div class="photo-item" onclick="openLightbox(0)">
        <div class="photo-placeholder" style="background:linear-gradient(135deg,#FFE4D6,#FFD4C0)">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Decoração
        </div>
        <div class="photo-overlay"><div class="photo-meta"><strong>Decoração da mesa</strong>Enviada por Camila</div></div>
        <div class="photo-actions">
          <button class="photo-action-btn" title="Baixar">⬇</button>
          <button class="photo-action-btn danger" title="Excluir">✕</button>
        </div>
      </div>

      <div class="photo-item" onclick="openLightbox(1)">
        <div class="photo-placeholder" style="background:linear-gradient(135deg,#EDE9F8,#DDD5F3)">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Bolo
        </div>
        <div class="photo-overlay"><div class="photo-meta"><strong>Bolo temático</strong>Enviada por Camila</div></div>
        <div class="photo-actions">
          <button class="photo-action-btn" title="Baixar">⬇</button>
          <button class="photo-action-btn danger" title="Excluir">✕</button>
        </div>
      </div>

      <div class="photo-item" onclick="openLightbox(2)">
        <div class="photo-placeholder" style="background:linear-gradient(135deg,#D4F0DF,#B8E6CA)">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Convidados
        </div>
        <div class="photo-overlay"><div class="photo-meta"><strong>Chegada dos convidados</strong>Enviada por Ana</div></div>
        <div class="photo-actions">
          <button class="photo-action-btn" title="Baixar">⬇</button>
          <button class="photo-action-btn danger" title="Excluir">✕</button>
        </div>
      </div>

      <div class="photo-item" onclick="openLightbox(3)">
        <div class="photo-placeholder" style="background:linear-gradient(135deg,#FFF3CC,#FFE99A)">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#D4A030" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Presentes
        </div>
        <div class="photo-overlay"><div class="photo-meta"><strong>Mesa de presentes</strong>Enviada por Camila</div></div>
        <div class="photo-actions">
          <button class="photo-action-btn" title="Baixar">⬇</button>
          <button class="photo-action-btn danger" title="Excluir">✕</button>
        </div>
      </div>

      <div class="photo-item" onclick="openLightbox(4)">
        <div class="photo-placeholder" style="background:linear-gradient(135deg,#DBEAFE,#BFDBFE)">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6B9BD2" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Brincadeiras
        </div>
        <div class="photo-overlay"><div class="photo-meta"><strong>Brincadeiras</strong>Enviada por João</div></div>
        <div class="photo-actions">
          <button class="photo-action-btn" title="Baixar">⬇</button>
          <button class="photo-action-btn danger" title="Excluir">✕</button>
        </div>
      </div>

      <div class="photo-item" onclick="openLightbox(5)">
        <div class="photo-placeholder" style="background:linear-gradient(135deg,#FCE4EC,#F8BBD0)">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#D88A9A" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Mamãe
        </div>
        <div class="photo-overlay"><div class="photo-meta"><strong>Mamãe feliz</strong>Enviada por Letícia</div></div>
        <div class="photo-actions">
          <button class="photo-action-btn" title="Baixar">⬇</button>
          <button class="photo-action-btn danger" title="Excluir">✕</button>
        </div>
      </div>

      <div class="photo-item" onclick="openLightbox(6)">
        <div class="photo-placeholder" style="background:linear-gradient(135deg,#FFE4D6,#FFD4C0)">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Lembrancinhas
        </div>
        <div class="photo-overlay"><div class="photo-meta"><strong>Lembrancinhas</strong>Enviada por Camila</div></div>
        <div class="photo-actions">
          <button class="photo-action-btn" title="Baixar">⬇</button>
          <button class="photo-action-btn danger" title="Excluir">✕</button>
        </div>
      </div>

      <div class="photo-item" onclick="openLightbox(7)">
        <div class="photo-placeholder" style="background:linear-gradient(135deg,#EDE9F8,#DDD5F3)">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Família
        </div>
        <div class="photo-overlay"><div class="photo-meta"><strong>Foto da família</strong>Enviada por Maria</div></div>
        <div class="photo-actions">
          <button class="photo-action-btn" title="Baixar">⬇</button>
          <button class="photo-action-btn danger" title="Excluir">✕</button>
        </div>
      </div>

      <div class="photo-item" onclick="openLightbox(8)">
        <div class="photo-placeholder" style="background:linear-gradient(135deg,#D4F0DF,#B8E6CA)">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Abrindo presentes
        </div>
        <div class="photo-overlay"><div class="photo-meta"><strong>Abrindo presentes</strong>Enviada por Fernando</div></div>
        <div class="photo-actions">
          <button class="photo-action-btn" title="Baixar">⬇</button>
          <button class="photo-action-btn danger" title="Excluir">✕</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <button class="lightbox-close" onclick="closeLightbox()">✕</button>
  <div class="lightbox-content">
    <div class="lightbox-placeholder">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
      <span id="lightboxLabel">Foto</span>
    </div>
  </div>
  <div class="lightbox-info">
    <strong id="lightboxTitle">Decoração da mesa</strong>
    <span id="lightboxAuthor">Enviada por Camila</span>
  </div>
  <div class="lightbox-nav">
    <button class="lightbox-nav-btn" onclick="navLightbox(-1)">←</button>
    <button class="lightbox-nav-btn" onclick="navLightbox(1)">→</button>
  </div>
</div>

<%- include('../partials/toast') %>
