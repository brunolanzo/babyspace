<%- include('../partials/sidebar') %>
<div class="main">
  <%- include('../partials/topbar') %>
  <div class="content">

    <!-- Section 1: Personal Data -->
    <div class="profile-section">
      <h3>Dados pessoais</h3>
      <div class="avatar-area">
        <div class="avatar-large">CL</div>
        <div class="avatar-actions">
          <button class="btn btn-outline btn-sm">📷 Alterar foto</button>
          <span style="font-size:0.8rem;color:var(--color-text-light)">JPG ou PNG, máximo 2MB</span>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Nome</label>
          <input type="text" class="form-input" value="Camila">
        </div>
        <div class="form-group">
          <label>Sobrenome</label>
          <input type="text" class="form-input" value="Lima Santos">
        </div>
      </div>
      <div class="form-group">
        <label>E-mail</label>
        <input type="email" class="form-input" value="camila.lima@email.com" disabled>
        <div class="form-hint">Para alterar seu e-mail, entre em contato com o suporte.</div>
      </div>
      <div class="form-group">
        <label>Telefone</label>
        <input type="tel" class="form-input" placeholder="(00) 00000-0000" value="(11) 99876-5432">
      </div>
      <div class="form-group">
        <label>Data prevista do parto</label>
        <input type="date" class="form-input" value="2026-05-15">
      </div>
      <button class="btn btn-primary" onclick="showToast('Dados salvos com sucesso!')">Salvar alterações</button>
    </div>

    <!-- Section 2: Change Password -->
    <div class="profile-section">
      <h3>Alterar senha</h3>
      <div class="form-group">
        <label>Senha atual</label>
        <div class="password-wrapper">
          <input type="password" class="form-input" placeholder="Digite sua senha atual" id="currentPass">
          <button class="eye-toggle" onclick="togglePass('currentPass',this)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
        </div>
      </div>
      <div class="form-group">
        <label>Nova senha</label>
        <div class="password-wrapper">
          <input type="password" class="form-input" placeholder="Mínimo 8 caracteres" id="newPass" oninput="checkStrength(this.value)">
          <button class="eye-toggle" onclick="togglePass('newPass',this)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
        </div>
        <div class="strength-bar" id="strengthBar">
          <div class="strength-segment" id="seg1"></div>
          <div class="strength-segment" id="seg2"></div>
          <div class="strength-segment" id="seg3"></div>
          <div class="strength-segment" id="seg4"></div>
        </div>
        <div class="strength-label" id="strengthLabel"></div>
      </div>
      <div class="form-group">
        <label>Confirmar nova senha</label>
        <div class="password-wrapper">
          <input type="password" class="form-input" placeholder="Repita a nova senha" id="confirmPass">
          <button class="eye-toggle" onclick="togglePass('confirmPass',this)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
        </div>
      </div>
      <button class="btn btn-primary" onclick="showToast('Senha alterada com sucesso!')">Alterar senha</button>
    </div>

    <!-- Section 3: Notifications -->
    <div class="profile-section">
      <h3>Notificações</h3>
      <div class="toggle-group">
        <div class="toggle-item">
          <div class="toggle-label">
            Novos presentes
            <span>Receba um alerta quando alguém comprar um presente</span>
          </div>
          <div class="toggle-switch active" onclick="this.classList.toggle('active')"><div class="toggle-knob"></div></div>
        </div>
        <div class="toggle-item">
          <div class="toggle-label">
            Novas mensagens no mural
            <span>Receba um alerta quando alguém deixar um recado</span>
          </div>
          <div class="toggle-switch active" onclick="this.classList.toggle('active')"><div class="toggle-knob"></div></div>
        </div>
        <div class="toggle-item">
          <div class="toggle-label">
            Confirmação de presença
            <span>Receba um alerta quando um convidado confirmar presença</span>
          </div>
          <div class="toggle-switch active" onclick="this.classList.toggle('active')"><div class="toggle-knob"></div></div>
        </div>
        <div class="toggle-item">
          <div class="toggle-label">
            Novas fotos no álbum
            <span>Receba um alerta quando alguém enviar uma foto</span>
          </div>
          <div class="toggle-switch" onclick="this.classList.toggle('active')"><div class="toggle-knob"></div></div>
        </div>
        <div class="toggle-item">
          <div class="toggle-label">
            E-mails de marketing
            <span>Novidades, dicas e promoções do BabySpace</span>
          </div>
          <div class="toggle-switch" onclick="this.classList.toggle('active')"><div class="toggle-knob"></div></div>
        </div>
      </div>
    </div>

    <!-- Section 4: Plan -->
    <div class="profile-section">
      <h3>Plano atual</h3>
      <div class="plan-card">
        <div class="plan-info">
          <h4>Plano Grátis <span class="plan-badge">Ativo</span></h4>
          <p>Ideal para quem está começando a organizar o chá</p>
        </div>
      </div>
      <div class="plan-features">
        <div class="plan-feature">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
          1 chá de bebê
        </div>
        <div class="plan-feature">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
          Até 30 presentes
        </div>
        <div class="plan-feature">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
          Mural de recados
        </div>
        <div class="plan-feature">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
          Álbum de fotos (20 fotos)
        </div>
        <div class="plan-feature locked">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Domínio personalizado
        </div>
        <div class="plan-feature locked">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Sem limite de fotos
        </div>
      </div>
      <div class="upgrade-banner">
        <div>
          <h4>Upgrade para Premium</h4>
          <p>Presentes ilimitados, domínio personalizado e muito mais!</p>
        </div>
        <button class="btn btn-white">Ver planos — R$ 29,90/mês</button>
      </div>
    </div>

    <!-- Section 5: Danger Zone -->
    <div class="danger-zone">
      <h3>⚠️ Zona de perigo</h3>
      <p>Ao excluir sua conta, todos os seus dados serão permanentemente removidos. Esta ação não pode ser desfeita.</p>
      <button class="btn btn-danger" onclick="document.getElementById('deleteModal').classList.add('open')">Excluir minha conta</button>
    </div>

  </div>
</div>

<!-- Delete Account Modal -->
<div class="modal-overlay" id="deleteModal">
  <div class="modal">
    <h2>Excluir conta permanentemente?</h2>
    <p>Todos os seus dados serão removidos, incluindo chás, presentes, fotos e mensagens. Esta ação é <strong>irreversível</strong>.</p>
    <div class="form-group">
      <label>Digite "EXCLUIR" para confirmar</label>
      <input type="text" class="form-input" placeholder="EXCLUIR" id="deleteConfirm" oninput="checkDelete()">
    </div>
    <div class="modal-actions">
      <button class="btn btn-danger" id="deleteBtn" disabled onclick="showToast('Conta excluída')">Excluir conta</button>
      <button class="btn btn-outline" onclick="document.getElementById('deleteModal').classList.remove('open')">Cancelar</button>
    </div>
  </div>
</div>

<%- include('../partials/toast') %>
